# pi-gen configuration for the forty-two-watts Raspberry Pi image.
# Sourced by pi-gen's build scripts — plain shell variables, no logic.

IMG_NAME="42w-rpi4-arm64"
RELEASE="bookworm"

# mDNS: the avahi-daemon shipped with Raspberry Pi OS picks up
# /etc/hostname as its primary .local name. Setting this to `42w`
# means the dashboard is reachable at http://42w.local:8080/ on any
# LAN with working mDNS (which is almost everything modern).
TARGET_HOSTNAME="42w"

LOCALE_DEFAULT="en_US.UTF-8"
KEYBOARD_KEYMAP="us"
KEYBOARD_LAYOUT="English (US)"
TIMEZONE_DEFAULT="UTC"

# Skip stage2 (Pi OS Lite "comfort" packages: vim, less, raspi-config,
# build-essential, python3-pip, network-manager-gnome, etc.) — none of
# its additions are needed for "boot → docker compose up". Stage-42w
# explicitly pulls the bits we DO need (avahi-daemon for mDNS,
# network-manager for wifi-connect) so we don't lose mDNS or WiFi
# onboarding by dropping stage2. Stage3-5 (desktop + NOOBS) are
# skipped separately via SKIP files in build.sh.
STAGE_LIST="stage0 stage1 stage-42w"

# First-login creds. Users who flash with Raspberry Pi Imager will
# override these via Imager's advanced-options panel (which writes to
# /boot/firmware/userconf.txt and supersedes FIRST_USER_*). These
# defaults exist so a user who flashes raw can still SSH in when
# something goes wrong.
FIRST_USER_NAME="ftw"
FIRST_USER_PASS="fortytwowatts"

# SSH enabled by default — the image has no console, so without SSH
# (or wifi-connect captive portal, landing in Phase 3) there's no
# recovery path if the web UI won't come up. Raspberry Pi Imager's
# advanced options can disable it per-flash if needed.
ENABLE_SSH=1

# Compress the exported image with xz. The combination matches what
# Raspberry Pi Imager expects and keeps the release asset under the
# 2 GB per-file cap that GitHub Releases enforces on public repos.
DEPLOY_COMPRESSION=xz
DEPLOY_ZIP=0
